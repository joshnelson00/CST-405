}

/* FUNCTION WITH WRONG PARAMETER USAGE */
int sumFive(int a, int b, int c, int d, int e) {
    int x;
    int y;
    int result;
    x = a + b + unknownParam;  /* ERROR: Undeclared parameter */
    y = d + e;
    result = x + y;
    return result;
}

int square(int n) {
    int result;
    result = n * n;
    return result;
}

/* ERROR: Duplicate function definition */
int square(int num) {
    return num * num;
}

int cube(int n) {
    int sq;
    int result;
    sq = square(n);
    result = sq * n;
    return result;
}

