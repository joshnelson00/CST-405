    /* ERROR: Array used as scalar */
    result = localArray;  /* Should be localArray[i] */

    /* Valid operations */
    a = 10;
    b = 20;
    c = 30;
    d = 40;
    e = 50;

    result = square(5);
    print(result);

    /* ERROR: Return outside function (in nested block) */
    {
