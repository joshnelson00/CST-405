    output[0] = 100;
    output[1] = 200;
    output[2] = 300;
    return 3;
}

/* FUNCTION: Uses array parameter */
int readArray(int input[]) {
    int val;
    val = input[0];
    val = input[0]  /* ERROR: Missing semicolon */
