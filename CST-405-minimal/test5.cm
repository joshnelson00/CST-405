/* Test: Print a 3x3 grid of coordinates */
void main() {
    int row;
    int col;

    row = 0;
    while (row < 3) {
        col = 0;
        while (col < 3) {
            print(row * 10 + col);
            print(", ");
            col = col + 1;
        }
        print("\n");
        row = row + 1;
    }
}

/* Expected output:
   00, 01, 02,
   10, 11, 12,
   20, 21, 22,
*/