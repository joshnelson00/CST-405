int main() {
    int a;
    int b;

    a = 1;
    b = 0;

    if (a && b) {
        print(100);
    } else {
        print(1);
    }

    if (a || b) {
        print(2);
    } else {
        print(200);
    }

    if (!b) {
        print(3);
    } else {
        print(300);
    }

    if (!(a && b)) {
        print(4);
    } else {
        print(400);
    }

    return 0;
}
