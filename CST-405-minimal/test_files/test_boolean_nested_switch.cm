int main() {
    int x;
    int y;

    x = 2;
    y = 0;

    if ((x > 1 && y == 0) || !(x == 2 && y == 1)) {
        switch (x) {
            case 1:
                print(10);
                break;
            case 2:
                if (!y || x > 10) {
                    print(20);
                } else {
                    print(21);
                }
                break;
            default:
                print(30);
                break;
        }
    } else {
        print(40);
    }

    return 0;
}
