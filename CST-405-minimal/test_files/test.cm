/* Smoke test — exercises arithmetic, if/else, while, for, and a function.
 * Expected output (one value per line):
 *   42   <- direct assignment
 *    1   <- if/else true branch
 *    0   <- if/else false branch
 *   10   <- while loop sum 1+2+3+4
 *   15   <- for  loop sum 1+2+3+4+5
 *   25   <- square(5) via function call
 */

int square(int n) {
    return n * n;
}

int main() {
    int x;
    int i;
    int s;
    int r;

    /* arithmetic */
    x = 6 * 7;
    print(x);           /* 42 */

    /* if/else */
    if (x > 40) {
        print(1);       /* 1  — true branch */
    } else {
        print(0);
    }
    if (x > 50) {
        print(1);
    } else {
        print(0);       /* 0  — false branch */
    }

    /* while loop: sum = 1+2+3+4 = 10 */
    s = 0;
    i = 1;
    while (i <= 4) {
        s = s + i;
        i = i + 1;
    }
    print(s);           /* 10 */

    /* for loop: sum = 1+2+3+4+5 = 15 */
    s = 0;
    for (i = 1; i <= 5; i = i + 1) {
        s = s + i;
    }
    print(s);           /* 15 */

    /* function call */
    r = square(5);
    print(r);           /* 25 */

    return 0;
}
