int main() {
    int a;
    int b;

    a = 1;
    b = 0;

    if (a && !b) {
        print(10);
    }

    if (a && b) {
        print(99);
    } else {
        print(20);
    }

    if (a || b) {
        print(30);
    } else {
        print(88);
    }

    switch (a + b) {
        case 0:
            print(77);
            break;
        case 1:
            print(40);
            break;
        default:
            print(66);
            break;
    }

    return 0;
}
