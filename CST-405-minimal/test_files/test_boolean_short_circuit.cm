int markTrue() {
    print(111);
    return 1;
}

int markFalse() {
    print(222);
    return 0;
}

int main() {
    if (0 && markTrue()) {
        print(900);
    } else {
        print(1);
    }

    if (1 || markTrue()) {
        print(2);
    } else {
        print(901);
    }

    if (0 || markFalse()) {
        print(902);
    } else {
        print(3);
    }

    if (1 && markTrue()) {
        print(4);
    } else {
        print(903);
    }

    return 0;
}
