/* Comprehensive switch-statement test adapted to MiniC grammar */

int grade(int score) {
    switch (score) {
        case 1: return 10;
        case 2: return 20;
        case 3: return 30;
        default: return 99;
    }
}

int main() {
    int x;

    /* Test 1: Simple dispatch */
    x = 2;
    switch (x) {
        case 1: print(10); break;
        case 2: print(20); break;
        case 3: print(30); break;
        default: print(0); break;
    }

    /* Test 2: Default clause */
    x = 99;
    switch (x) {
        case 1: print(10); break;
        case 2: print(20); break;
        default: print(0); break;
    }

    /* Test 3: break stops execution */
    x = 3;
    switch (x) {
        case 3: print(30); break;
        case 4: print(40); break;
        default: print(0); break;
    }

    /* Test 4: Fall-through */
    x = 4;
    switch (x) {
        case 4:
        case 5: print(10); break;
        default: print(0); break;
    }

    /* Test 5: Expression as controlling value */
    x = 15;
    int d;
    d = x / 10;
    switch (d) {
        case 0: print(0); break;
        case 1: print(1); break;
        case 2: print(2); break;
        default: print(9); break;
    }

    /* Test 6: switch inside a function */
    int g;
    g = grade(3);
    switch (g) {
        case 30: print(7); break;
        default: print(0); break;
    }

    /* Test 7: Nested switch */
    int outer;
    int inner;
    outer = 2;
    inner = 10;
    switch (outer) {
        case 1:
            switch (inner) {
                case 10: print(100); break;
                default: print(0); break;
            }
            break;
        case 2:
            switch (inner) {
                case 10: print(200); break;
                default: print(0); break;
            }
            break;
        default: print(0); break;
    }

    /* Test 8: break inside switch */
    int i;
    i = 0;
    switch (i) {
        case 0:
            i = 1;
            break;
        default:
            i = 0;
            break;
    }
    print(i);

    return 0;
}
